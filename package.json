{
  "name": "perceptible",
  "version": "1.0.1",
  "description": "detect visibility of DOM Elements",
  "keywords": [
    "dom",
    "viewability",
    "visibility",
    "intersection-observer",
    "observer",
    "viewport",
    "scroll",
    "attention",
    "tracking",
    "performance",
    "impression",
    "impressions",
    "ads",
    "ad-viewability",
    "telemetry",
    "analytics",
    "exposure"
  ],
  "main": "dist/bundle.js",
  "module": "dist/bundle.mjs",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bundle.mjs",
      "require": "./dist/bundle.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "vite build --watch",
    "build": "vite build",
    "sample": "npx http-server -o",
    "lint": "eslint ./src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest e2e/browser.test.js --testPathIgnorePatterns='^$' ",
    "release": "npx release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anubhavsrivastava/perceptible.git"
  },
  "author": {
    "name": "Anubhav Srivastava",
    "email": "anubhav.srivastava00@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anubhavsrivastava/perceptible/issues"
  },
  "homepage": "https://github.com/anubhavsrivastava/perceptible#readme",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "babel-jest": "^30.4.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jest": "^29.15.4",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "puppeteer": "^25.3.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3"
  }
}
